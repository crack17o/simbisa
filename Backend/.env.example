# Django
SECRET_KEY=your-256-bit-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
DB_NAME=simbisa_db
DB_USER=simbisa_user
DB_PASSWORD=simbisa_dev_password
DB_HOST=localhost
DB_PORT=3306
DB_ROOT_PASSWORD=simbisa_root_password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=strong-redis-password

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# E-mail Gmail (mot de passe d'application Google — https://myaccount.google.com/apppasswords)
# Si renseigné, les OTP / reset / bienvenue partent par SMTP ; sinon affichés dans la console Django.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Simbisa Rawbank <simbisa.cd@gmail.com>

# LLM & RAG (Gemini par défaut — OpenAI en alternative)
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# OpenAI (optionnel si LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
RAG_RETRIEVAL_K=5

# Devises (taux indicatif CDF/USD pour plages crédit CDF)
CDF_PER_USD=2250

# USSD (simulateur — pas de telco)
USSD_SESSION_TTL=180
USSD_SIMULATOR_ENABLED=True
USSD_DEFAULT_PIN=0000
USSD_CALLBACK_SECRET=simulator-dev-secret
USSD_REQUIRE_SECRET=False

# ML Models
ML_MODEL_PATH=mltraining/models/xgboost_v2.joblib
ML_SCALER_PATH=mltraining/models/scaler.joblib
ML_FEATURES_PATH=mltraining/models/features.json

# Sentry
SENTRY_DSN=

# Cloudinary (documents KYC — production)
# Dashboard : https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
